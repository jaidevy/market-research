# Copy to .env and fill values for live Upstox data
# cp .env.example .env (Linux/macOS)
# copy .env.example .env (Windows cmd)

UPSTOX_ANALYTICS_TOKEN=
UPSTOX_INSTRUMENT_KEY=NSE_INDEX|Nifty 50

# Optional app toggles
MARKET_DATA_PROVIDER=upstox
e
AUTO_RESEARCH_ENABLED=true

# Agentic runtime and model routing
AGENTIC_ENABLED=true
AGENTIC_USE_DEEPAGENTS=true
AGENTIC_MODEL=gpt-4.1-mini
AGENTIC_MODEL_PROVIDER=openai
AGENTIC_SKILLS_DIR=skills/auto_research
OPENAI_API_KEY=

# Optional live news RSS feeds (JSON array or comma-separated values)
NEWS_FEED_URLS=["https://news.google.com/rss/search?q=Nifty%2050%20OR%20NSE%20OR%20RBI&hl=en-IN&gl=IN&ceid=IN:en","https://news.google.com/rss/search?q=Indian%20stock%20market%20OR%20FII%20OR%20Fed&hl=en-IN&gl=IN&ceid=IN:en"]

# Discord channel integration (agent tool handles read/write)
DISCORD_PROVIDER=agent_tool
# When using external delivery set DISCORD_PROVIDER=webhook
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_USERNAME=Market Research Bot

# Optional: secret used to validate incoming webhook signatures
DISCORD_WEBHOOK_SECRET=

# Discord bot gateway (true two-way events via discord.py)
# Provide the token from the Discord Developer Portal. The Django backend
# autostarts the bot during `make run-backend` / `make run-full` when this is set.
# https://discord.com/developers/applications  →  Your App → Bot → Reset Token
DISCORD_BOT_TOKEN=
DISCORD_BOT_AUTOSTART=true
DISCORD_BOT_TARGET_AGENT=ConciergeAgent
